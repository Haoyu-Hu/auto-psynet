            node_class={{NODE_CLASS}},
            start_nodes=start_nodes,            # NOT nodes= — chains use start_nodes (gotcha)
            chain_type="{{CHAIN_TYPE}}",         # "across" (canonical for hybrid/iterated learning) or "within"
            max_nodes_per_chain={{MAX_NODES_PER_CHAIN}},   # chain depth (number of generations)
