import random
import psynet.experiment
from markupsafe import Markup
from psynet.consent import MainConsent
from psynet.modular_page import ModularPage, SliderControl
from psynet.page import InfoPage
from psynet.timeline import Timeline
from psynet.trial.gibbs import GibbsNode, GibbsTrial, GibbsTrialMaker


# --- Node -----------------------------------------------------------------------------------------
# vector_length is the dimensionality of the perceptual space being sampled; vector_ranges is a list
# of (min, max) per dimension. For media variants, subclass a *GibbsNode and define synth_function +
# granularity (see psynet/trial/media_gibbs.py).
class {{NODE_CLASS}}(GibbsNode):
    vector_length = {{VECTOR_LENGTH}}
    vector_ranges = {{VECTOR_RANGES}}      # e.g. [(0, 255), (0, 255), (0, 255)] for RGB

    def random_sample(self, i):
        lo, hi = self.vector_ranges[i]
        return random.uniform(lo, hi)


# --- Trial ----------------------------------------------------------------------------------------
# Each trial varies ONE dimension (self.active_index) of the current vector (self.vector). The slider
# proposes a new value for that dimension; the resulting vector becomes the next node in the chain.
class {{TRIAL_CLASS}}(GibbsTrial):
    time_estimate = {{TRIAL_TIME}}        # seconds — REQUIRED

    def show_trial(self, experiment, participant):
        vec = list(self.vector)
        i = self.active_index
        lo, hi = {{NODE_CLASS}}.vector_ranges[i]
        prompt_html = {{PROMPT_HTML_EXPR}}     # a Python f-string using `vec`, `i`, `lo`, `hi`
        return ModularPage(
            "gibbs_trial",
            Markup(prompt_html),
            SliderControl(
                min_value=lo,
                max_value=hi,
                default_value=vec[i],
                bot_response={{BOT_RESPONSE}},   # REQUIRED so bot tests pass; LLM-pilot driver overrides
            ),
            time_estimate=self.time_estimate,
        )


# --- TrialMaker -----------------------------------------------------------------------------------
class {{TRIAL_MAKER_CLASS}}(GibbsTrialMaker):
    pass


# --- Start nodes (one per chain; chain_type="across" — chains shared across participants) ---------
start_nodes = [{{NODE_CLASS}}() for _ in range({{N_CHAINS}})]


